# HRestroSewa — environment template.
#
# Copy to `.env.local` for local/internal testing (pointed at the DEV Supabase
# project), and keep production values OUT of the repo — every real `.env*` file
# is gitignored. Nothing here is secret; replace each placeholder.
#
# Which file Next.js loads:
#   npm run dev                  → .env.local
#   npm run build && npm start   → .env.production, BUT .env.local still WINS if
#                                  it exists. So a production build run on this
#                                  machine talks to the DEV project. That is the
#                                  safe default; to test against production
#                                  locally you must temporarily move .env.local
#                                  aside. On a host (Vercel etc.) these files are
#                                  not used at all — set the vars in its dashboard.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key — safe to expose to the browser>

# Project Settings → API. NEVER goes in the browser and never in git: it bypasses
# RLS completely, so it can read and write every restaurant's data.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Project Settings → Database → Connection string → **Session pooler**.
# Use the POOLER host (aws-N-<region>.pooler.supabase.com), not the direct
# `db.<ref>.supabase.co` host — the direct one is IPv6-only on most networks and
# will fail with ENETUNREACH or a timeout.
# Used by the realtime bus (lib/realtime/bus.ts) and by the migration/test
# tooling, so a wrong value breaks live updates in the app, not just scripts.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<db-password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ── Web push (PWA notifications) ──────────────────────────────────────────────
# Generate once with:  npx web-push generate-vapid-keys
# The pair must MATCH the subscriptions stored in the database — regenerating
# them invalidates every existing device subscription, so a dev project should
# have its own pair rather than borrowing production's.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid public key>
VAPID_PRIVATE_KEY=<vapid private key>
VAPID_SUBJECT=mailto:you@example.com
